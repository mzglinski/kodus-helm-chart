{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "mergeConfidence:all-badges"],
  "addLabels": ["renovate"],
  "assignees": ["mzglinski"],
  "configMigration": true,
  "lockFileMaintenance": {
    "enabled": false
  },
  "minimumReleaseAge": "3 days",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "semanticCommits": "enabled",
  "platformAutomerge": true,
  "rebaseWhen": "behind-base-branch",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["chart/Chart.yaml", "chart/values.yaml"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s+\\w+\\s*:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/.*\\.ya?ml$/",
        "/chart/ci/.*\\.ya?ml/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\n\\s*\\w[-\\w]*\\s*:\\s*[\"']?v?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["Makefile"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s+\\w[-\\w]*\\s*\\?=\\s*(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/.*\\.ya?ml$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+registryUrl=(?<registryUrl>\\S+))?\\s*\\n.*--version\\s+(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/.*\\.ya?ml$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\n.*releases/download/v?(?<currentValue>[^/\"'\\s]+)/"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/chart/ci/.*\\.ya?ml/"],
      "matchStrings": [
        "(?:imageName|reference|image):\\s*['\"]?(?<depName>[^@\\s'\"]+):(?<currentValue>[^\\s@'\"]+)(?:@(?<currentDigest>[^\\s'\"]+))?['\"]?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/chart/ci/.*\\.ya?ml/"],
      "matchStrings": [
        "releases/download/v(?<currentValue>[^/\"'\\s]+)/rabbitmq_delayed_message_exchange-",
        "echo \"(?<currentValue>[a-f0-9]{64})  /plugins/rabbitmq_delayed_message_exchange.ez\" | sha256sum -c -"
      ],
      "depNameTemplate": "rabbitmq-delayed-message-exchange",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "rabbitmq/rabbitmq-delayed-message-exchange"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchCurrentVersion": "<1",
      "matchUpdateTypes": ["minor"],
      "automerge": false
    },
    {
      "matchDepNames": ["kodustech/kodus-ai"],
      "groupName": "kodus-ai",
      "automerge": false,
      "extractVersion": "^selfhosted-(?<version>.*)$"
    },
    {
      "matchDepNames": ["kodustech/kodus-ai"],
      "matchUpdateTypes": ["patch"],
      "semanticCommitType": "fix"
    },
    {
      "matchDepNames": ["kodustech/kodus-ai"],
      "matchUpdateTypes": ["minor"],
      "semanticCommitType": "feat"
    },
    {
      "matchDepNames": ["kodustech/kodus-ai"],
      "matchUpdateTypes": ["major"],
      "semanticCommitType": "feat!"
    },
    {
      "matchDepNames": ["norwoodj/helm-docs"],
      "groupName": "helm-docs"
    },
    {
      "description": "rabbitmq_delayed_message_exchange requires RabbitMQ <4.3 (Mnesia removed in 4.3)",
      "matchPackageNames": ["rabbitmq", "docker.io/rabbitmq"],
      "allowedVersions": "<4.3.0"
    }
  ],
  "ignorePaths": ["**/node_modules/**"]
}
